{
	"name": "@nicbat/svelte-masonry",
	"version": "0.1.0",
	"description": "A generic, dependency-free balanced masonry layout for Svelte 5. Order-preserving column packing that estimates tile height from an aspect ratio for balancing only — never a fixed pixel height, so a wrong or absent ratio can never clip or misalign a tile.",
	"keywords": [
		"svelte",
		"svelte5",
		"masonry",
		"layout",
		"grid",
		"component"
	],
	"license": "MIT",
	"author": "nicbat",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/nicbat/svelte-masonry.git"
	},
	"homepage": "https://github.com/nicbat/svelte-masonry#readme",
	"bugs": {
		"url": "https://github.com/nicbat/svelte-masonry/issues"
	},
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run package",
		"preview": "vite preview",
		"package": "svelte-kit sync && svelte-package && publint",
		"prepublishOnly": "npm run package",
		"prepare": "svelte-kit sync && svelte-package",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"format": "prettier --write .",
		"lint": "prettier --check ."
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.16.0",
		"@sveltejs/package": "^2.3.7",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"publint": "^0.3.2",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0"
	}
}
